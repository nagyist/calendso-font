# FEATURE: locl
script latn;

# Turkish, Azerbaijani, Crimean Tatar, Kazakh, Tatar
language AZE exclude_dflt;
lookup locl_latn_TRK {
    sub i by idotaccent;
} locl_latn_TRK;

language CRT exclude_dflt;
lookup locl_latn_TRK;

language KAZ exclude_dflt;
lookup locl_latn_TRK;

language TAT exclude_dflt;
lookup locl_latn_TRK;

language TRK exclude_dflt;
lookup locl_latn_TRK;


# Romanian and Moldovan
language ROM exclude_dflt;
lookup locl_latn_ROM {
    sub Scedilla by Scommaaccent;
    sub scedilla by scommaaccent;
    sub Tcedilla by Tcommaaccent;
    sub tcedilla by tcommaaccent;
    
    # Alternates explicitly mapped from your glyphset
    sub tcedilla.rcltGeo by tcommaaccent.rcltGeo;
    sub tcedilla.rcltBase by tcommaaccent.rcltBase;
    sub tcedilla.ss08 by tcommaaccent.ss08;
    sub tcedilla.ss10 by tcommaaccent.ss10;
} locl_latn_ROM;

language MOL exclude_dflt;
lookup locl_latn_ROM;


# Catalan
language CAT exclude_dflt;
lookup locl_latn_CAT {
    sub l periodcentered' l by periodcentered.loclCAT;
    sub L periodcentered' L by periodcentered.loclCAT.case;
    
    # Alternates explicitly mapped from your glyphset
    sub l.rcltA11y periodcentered' l.rcltA11y by periodcentered.loclCAT;
    sub l.ss14 periodcentered' l.ss14 by periodcentered.loclCAT;
    sub l.ss16 periodcentered' l.ss16 by periodcentered.loclCAT;
} locl_latn_CAT;


# Dutch
language NLD exclude_dflt;
lookup locl_latn_NLD {
    sub iacute j' by jacute;
    sub Iacute J' by Jacute;
} locl_latn_NLD;

# Marshallese
language MAH exclude_dflt;
lookup locl_latn_MAH {
    sub Lcommaaccent by Lcommaaccent.loclMAH;
    sub Ncommaaccent by Ncommaaccent.loclMAH;
    sub Mcommaaccent by Mcommaaccent.loclMAH;
    sub lcommaaccent by lcommaaccent.loclMAH;
    sub ncommaaccent by ncommaaccent.loclMAH;
    sub commaaccentcomb by commaaccentcomb.loclMAH;
    
    # Alternates explicitly mapped from your glyphset
    sub Mcommaaccent.ss09 by Mcommaaccent.loclMAH.ss09;
    sub Mcommaaccent.rcltGeo by Mcommaaccent.loclMAH.rcltGeo;
    sub lcommaaccent.rcltA11y by lcommaaccent.loclMAH.rcltA11y;
    sub lcommaaccent.ss14 by lcommaaccent.loclMAH.ss14;
    
    sub Ocommaaccent by Ocommaaccent.loclMAH;
    sub ocommaaccent by ocommaaccent.loclMAH;
    sub mcommaaccent by mcommaaccent.loclMAH;
} locl_latn_MAH;


