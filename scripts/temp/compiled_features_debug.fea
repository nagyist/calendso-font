# PREFIX: Languagesystems
languagesystem DFLT dflt;

languagesystem latn dflt;
languagesystem latn AZE;
languagesystem latn CRT;
languagesystem latn KAZ;
languagesystem latn TAT;
languagesystem latn TRK;
languagesystem latn ROM;
languagesystem latn MOL;
languagesystem latn CAT;
languagesystem latn NLD;
languagesystem latn MAH;


# PREFIX: VARIATIONS
conditionset cond_micro_8 { opsz 8 8.5; } cond_micro_8;
  variation kern cond_micro_8  { pos @All <0 0 10 0>; } kern;

conditionset cond_micro_85 { opsz 8.5 9;   } cond_micro_85;
  variation kern cond_micro_85 { pos @All <0 0 8 0>; } kern;

conditionset cond_micro_9  { opsz 9   9.5; } cond_micro_9;
  variation kern cond_micro_9  { pos @All <0 0 5 0>; } kern;

conditionset cond_micro_95 { opsz 9.5 10;  } cond_micro_95;
  variation kern cond_micro_95 { pos @All <0 0 3 0>; } kern;

# ==========================================
# 1. Condition Sets
