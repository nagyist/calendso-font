    sub slashlongcomb by slashlongcomb.case;
} case;

feature liga {
    # automatic
    lookupflag IgnoreMarks;
    sub f f i by f_f_i;
    sub f f l by f_f_l;
    sub f i by fi;
    sub f l by fl;
} liga;

feature titl {
    sub one by one.disp;
    sub one.rcltGeo by one.disp;
    sub zero by zero.disp;
    sub six by six.disp;
    #sub seven by seven.disp;
    sub nine by nine.disp;
    sub zero.rcltGeo by zero.disp;
    sub zero.zero by zero.zero.disp;
    sub zero.zero.rcltGeo by zero.zero.disp;
} titl;

feature dlig {
    lookupflag IgnoreMarks;
    sub f t by f_t;
    sub f i by fi.rcltBase;
    sub f l by fl.rcltBase;
} dlig;

feature zero {
    # automatic
    sub zero by zero.zero;
} zero;

