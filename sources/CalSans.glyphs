  # Eng/eng Geo — 80–100
  condition 79 < GEOM;
  lookup GEOM_GEO_eng {
    sub Eng by Eng.rcltGeo;
    sub eng by eng.rcltGeo;
  } GEOM_GEO_eng;

  # one Geo — 80–100
  condition 79 < GEOM;
  lookup GEOM_GEO_one {
    sub one by one.rcltGeo;
    sub one.tf by one.tf.rcltGeo;
    sub one.lf by one.lf.rcltGeo;
  } GEOM_GEO_one;

  # zero Geo — 80–100
  condition 79 < GEOM;
  lookup GEOM_GEO_zero {
    sub zero by zero.rcltGeo;
    sub zero.zero by zero.zero.rcltGeo;
    sub zero.tf by zero.tf.rcltGeo;
    sub zero.lf by zero.lf.rcltGeo;
  } GEOM_GEO_zero;

  # euro Geo — 80–100
  condition 79 < GEOM;
  lookup GEOM_GEO_euro {
    sub euro by euro.rcltGeo;
    sub euro.tf by euro.tf.rcltGeo;
  } GEOM_GEO_euro;

  # M family Geo — 80–100
  condition 79 < GEOM;
  lookup GEOM_GEO_M {
    sub M by M.rcltGeo;
    sub Mdotbelow by Mdotbelow.rcltGeo;
    sub Mdotaccent by Mdotaccent.rcltGeo;
    sub Mcommaaccent by Mcommaaccent.rcltGeo;
    sub Mcommaaccent.loclMAH by Mcommaaccent.loclMAH.rcltGeo;
  } GEOM_GEO_M;
";
